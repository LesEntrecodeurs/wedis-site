# ─────────────────────────────────────────────────────────────────────────
# Config serveur de la vitrine (une vitrine = un shop).
# Copier en `.env` et renseigner. NE JAMAIS committer de vraies valeurs.
# Variables server-only (jamais NEXT_PUBLIC_, sauf NEXT_PUBLIC_SITE_URL).
# ─────────────────────────────────────────────────────────────────────────

# API Extracom (server-only). En local : l'API NestJS.
EXTRACOM_API_URL=http://localhost:3000

# Shop ambiant — doit exister côté Sage/Extracom.
EXTRACOM_SHOP=BIJOU

# Secret de chiffrement du cookie de session brokerée (AES-256-GCM).
# Générer une valeur forte et UNIQUE par site : openssl rand -base64 32
EXTRACOM_SESSION_SECRET=change-me-with-a-long-random-secret

# (Optionnel) Durée « rester connecté » du cookie de session, en secondes.
# Défaut : 604800 (7 jours).
# EXTRACOM_SESSION_MAX_AGE=604800

# (Optionnel) Rotation de clé SANS déconnecter les utilisateurs : mettre
# l'ANCIEN secret ici, le NOUVEAU dans EXTRACOM_SESSION_SECRET. Les cookies
# déjà posés restent valides en lecture jusqu'à leur renouvellement ; retirer
# cette ligne après la fenêtre de rotation (≈ EXTRACOM_SESSION_MAX_AGE).
# EXTRACOM_SESSION_SECRET_PREVIOUS=ancien-secret

# URL publique du site (metadataBase, OpenGraph, sitemap, JSON-LD,
# et retour de paiement). En local, le template tourne sur :3001.
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Host + protocole des images produit. L'API sert les photos via son propre
# proxy public (…/storefront/media/:filename, jamais l'hôte LAN Sage brut,
# injoignable depuis l'extérieur) — donc EXTRACOM_MEDIA_HOST = le MÊME host que
# EXTRACOM_API_URL (sans protocole), ex. api.extracom.fr. Autorisé par
# next/image (remotePatterns). Laisser EXTRACOM_MEDIA_HOST vide ⇒ images =
# placeholder.
EXTRACOM_MEDIA_HOST=
EXTRACOM_MEDIA_PROTOCOL=https
